@startuml C4_Componentes_IBVB
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Componentes — Site e administração IBVB

Person(visitante, "Visitante")
Person(editor, "Editor")

Container_Boundary(frontend, "Frontend estático") {
  Component(home, "Página inicial", "index.html", "Apresentação, mensagens, cultos e destaques")
  Component(agenda, "Agenda", "agenda.html", "Cultos recorrentes e todos os eventos")
  Component(panel, "Painel", "painel.html", "Login e formulários administrativos")
  Component(loader, "Carregador público", "JavaScript", "Busca o JSON e preenche o DOM")
}

Container_Boundary(backend, "API administrativa") {
  Component(auth, "Autenticação", "scrypt + sessões", "Login, expiração, rate limit e cookies")
  Component(validation, "Validação e CSRF", "Node.js", "Protege e normaliza atualizações")
  Component(storage, "Persistência", "Node.js filesystem", "Gravação atômica, backups e auditoria")
}

ComponentDb(json, "Conteúdo", "Volume Docker", "conteudo.json")

Rel(visitante, home, "Navega")
Rel(visitante, agenda, "Consulta")
Rel(editor, panel, "Gerencia")
Rel(home, loader, "Inicializa")
Rel(agenda, loader, "Inicializa")
Rel(loader, json, "Lê")
Rel(panel, auth, "Autentica", "JSON/HTTPS")
Rel(panel, validation, "Consulta e salva", "JSON/HTTPS + CSRF")
Rel(validation, storage, "Entrega conteúdo validado")
Rel(storage, json, "Lê e grava")

SHOW_LEGEND()
@enduml
