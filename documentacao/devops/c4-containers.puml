@startuml C4_Containers_IBVB
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Contêineres — Site IBVB

Person(visitante, "Visitante")
Person(editor, "Editor")

System_Boundary(ibvb, "Site IBVB") {
  Container(web, "Site e painel", "Nginx + HTML/JavaScript", "Entrega páginas públicas e a interface /admin")
  Container(api, "API administrativa", "Node.js", "Autenticação, validação, backups e auditoria")
  ContainerDb(content, "Conteúdo persistente", "Volume Docker / JSON", "Conteúdo atual, 30 backups e log de auditoria")
}

System_Ext(externals, "Serviços externos", "CDNs, YouTube, Maps, WhatsApp e Instagram")

Rel(visitante, web, "Acessa", "HTTPS")
Rel(editor, web, "Usa /admin", "HTTPS")
Rel(web, api, "Encaminha /api/admin", "HTTP interno")
Rel(api, content, "Lê, valida e grava", "Filesystem")
Rel(web, content, "Serve conteudo.json", "Filesystem somente leitura")
Rel(web, externals, "Carrega recursos e abre links", "HTTPS")

SHOW_LEGEND()
@enduml
