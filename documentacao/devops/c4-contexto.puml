@startuml C4_Contexto_IBVB
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title Contexto — Site IBVB

Person(visitante, "Visitante", "Consulta informações, mensagens, cultos e eventos")
Person(editor, "Editor", "Mantém o conteúdo por uma área restrita")

System(site, "Site IBVB", "Site institucional e painel administrativo")

System_Ext(git, "GitHub", "Código-fonte e pipeline de implantação")
System_Ext(midia, "Serviços externos", "YouTube, Google Maps, Instagram, WhatsApp, fontes e CDN")

Rel(visitante, site, "Navega", "HTTPS")
Rel(editor, site, "Autentica e edita em /admin", "HTTPS")
Rel(git, site, "Implanta novas versões", "GitHub Actions / SSH")
Rel(site, midia, "Carrega mídia e abre contatos", "HTTPS")

SHOW_LEGEND()
@enduml
