COMPOSE_PROJECT_NAME=site-ibvb
SITE_IMAGE=site-ibvb:local
SITE_CONTAINER_NAME=site-ibvb
SITE_HOST=127.0.0.1
SITE_PORT=2027
RESTART_POLICY=unless-stopped

# Painel administrativo. Consulte documentacao/admin.md.
ADMIN_IMAGE=site-ibvb-admin:local
ADMIN_CONTAINER_NAME=site-ibvb-admin
ADMIN_USERNAME=admin
# Opcao simples: senha com no minimo 12 caracteres.
ADMIN_PASSWORD=
# Opcao recomendada em producao: se preenchida, tem prioridade sobre ADMIN_PASSWORD.
ADMIN_PASSWORD_HASH=''
